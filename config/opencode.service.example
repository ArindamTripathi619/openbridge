[Unit]
Description=OpenCode API Server
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/DevCrewX/Projects/TelegramRemoteProgressBot
EnvironmentFile=%h/.config/telewatch/bridge.env
ExecStart=opencode serve --hostname 127.0.0.1 --port 4096
Restart=on-failure
RestartSec=5
StartLimitIntervalSec=60
StartLimitBurst=5
NoNewPrivileges=true

[Install]
WantedBy=default.target
