{
  "workflows": [
    {
      "id": "daily_news_digest",
      "name": "Daily News Digest",
      "enabled": true,
      "timezone": "local",
      "schedule": "daily@06:55",
      "targets": [0],
      "metadata": {
        "owner": "openbridge",
        "purpose": "morning_news_brief"
      },
      "steps": [
        {
          "type": "http_fetch",
          "normalize": "rss_digest",
          "max_items": 12,
          "sources": [
            "https://feeds.bbci.co.uk/news/rss.xml",
            "https://rss.nytimes.com/services/xml/rss/nyt/World.xml"
          ],
          "timeout_seconds": 20
        },
        {
          "type": "transform_python",
          "mode": "compact_whitespace"
        },
        {
          "type": "opencode_prompt",
          "prompt_template": "Create a concise morning news digest from the following source material. Include the top headlines, a one-line summary for each, and a short 'why it matters' section.\n\n{input}"
        },
        {
          "type": "telegram_send"
        }
      ]
    },
    {
      "id": "personal_gmail_digest",
      "name": "Personal Gmail Digest",
      "enabled": true,
      "timezone": "local",
      "schedule": "cron:0 9 * * *",
      "targets": [0],
      "metadata": {
        "owner": "openbridge",
        "mode": "opencode_internal_mcp",
        "mcp_profile": "gws-arindam"
      },
      "steps": [
        {
          "type": "opencode_prompt",
          "prompt_template": "Using MCP server profile gws-arindam, fetch the top 10 most important Gmail messages from the past 24 hours and create a concise digest. For each mail include sender, subject, and one-line why-it-matters. Group similar threads and keep the final output short and actionable."
        },
        {
          "type": "telegram_send"
        }
      ]
    }
  ]
}
