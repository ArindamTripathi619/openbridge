# API-mode environment reference for TeleWatch.
#
# Copy this file to your shell profile or source it before running the bridge.
# The bot sends prompts to `opencode serve` and does not run direct `!gws`/`/gws`
# command execution from Telegram.

# Required
export TELEGRAM_BOT_TOKEN="<BOT_TOKEN>"

# Optional but recommended
export OPENCODE_MODEL="opencode/big-pickle"
export OPENCODE_WORKING_DIR="/path/to/your/project"
export OPENCODE_TIMEOUT_SECONDS="600"
export OPENCODE_MAX_CONCURRENT="1"
export OPENCODE_API_BASE_URL="http://127.0.0.1:4096"
export OPENCODE_API_USERNAME="opencode"
export OPENCODE_API_PASSWORD=""
export OPENCODE_API_TIMEOUT_SECONDS="120"
export OPENCODE_SERVER_USERNAME="opencode"
export OPENCODE_SERVER_PASSWORD=""

# Optional chat allowlist (comma-separated numeric IDs)
# If omitted, bot accepts messages from any chat that can reach it.
export TELEGRAM_ALLOWED_CHAT_IDS="<CHAT_ID_1>,<CHAT_ID_2>"

# Optional logging level: DEBUG, INFO, WARNING, ERROR
export LOG_LEVEL="INFO"

# Optional input prompt enhancer LLM
export TELEWATCH_INPUT_LLM_ENABLED="0"
export TELEWATCH_INPUT_LLM_PROVIDER="litellm"
export TELEWATCH_INPUT_LLM_API_KEY="sk-local"
export TELEWATCH_INPUT_LLM_MODEL="groq-gpt-oss-mini"
export TELEWATCH_INPUT_LLM_BASE_URL=""
export TELEWATCH_INPUT_LLM_LITELLM_PORT="8000"
export TELEWATCH_INPUT_LLM_TIMEOUT_SECONDS="30"

# Optional output prettifier LLM
export TELEWATCH_OUTPUT_LLM_ENABLED="0"
export TELEWATCH_OUTPUT_LLM_PROVIDER="litellm"
export TELEWATCH_OUTPUT_LLM_API_KEY="sk-local"
export TELEWATCH_OUTPUT_LLM_MODEL="groq-gpt-oss-mini"
export TELEWATCH_OUTPUT_LLM_BASE_URL=""
export TELEWATCH_OUTPUT_LLM_LITELLM_PORT="8000"
export TELEWATCH_OUTPUT_LLM_TIMEOUT_SECONDS="30"

# Legacy output decorator variables (kept for backward compatibility)
export TELEWATCH_DECORATOR_ENABLED="0"
export TELEWATCH_DECORATOR_API_KEY=""
export TELEWATCH_DECORATOR_MODEL=""
export TELEWATCH_DECORATOR_BASE_URL=""
export TELEWATCH_DECORATOR_TIMEOUT_SECONDS="30"
